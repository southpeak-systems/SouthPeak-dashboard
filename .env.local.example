# ── Supabase ─────────────────────────────────────────────────────
# Found in: Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Service role key — used server-side only to create client auth accounts.
# NEVER expose this to the browser. Keep it out of version control.
# Found in: Supabase project → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
